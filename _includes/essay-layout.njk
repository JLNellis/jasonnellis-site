<!doctype html>
<html lang="en">
<head>
<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-PP4FTXFZRX"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-PP4FTXFZRX');
</script>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ title }} — Jason Nellis</title>
<meta name="description" content="{{ description }}">
<!-- Open Graph / Twitter -->
<meta property="og:type" content="article">
<meta property="og:url" content="https://jasonnellis.com{{ page.url }}">
<meta property="og:title" content="{{ title }} — Jason Nellis">
<meta property="og:description" content="{{ description }}">
<meta property="og:image" content="https://jasonnellis.com/og-image.png">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ title }} — Jason Nellis">
<meta name="twitter:description" content="{{ description }}">
<meta name="twitter:image" content="https://jasonnellis.com/og-image.png">
<link rel="canonical" href="https://jasonnellis.com{{ page.url }}">
<link rel="icon" type="image/png" href="/favicon.png">
<link rel="apple-touch-icon" href="/favicon.png">
<link rel="stylesheet" href="/site.css">
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": {{ title | dump | safe }},
  "description": {{ description | dump | safe }},
  "datePublished": "{{ date | isoDate }}",
  "author": { "@type": "Person", "name": "Jason Nellis", "url": "https://jasonnellis.com" },
  "publisher": { "@type": "Person", "name": "Jason Nellis" },
  "image": "https://jasonnellis.com/og-image.png",
  "mainEntityOfPage": "https://jasonnellis.com{{ page.url }}"
}
</script>
<style>
  .post-header { padding: 72px 0 8px; max-width: 720px; }
  .post-header .back-link { font-size: 13px; }
  .post-header .section-eyebrow { margin-top: 22px; }
  .post-header h1 {
    font-size: clamp(32px, 5vw, 48px); font-weight: 700;
    line-height: 1.15; letter-spacing: -0.02em; margin: 0 0 16px;
  }
  .post-header .post-desc { font-size: 17px; line-height: 1.6; color: var(--fg-2); margin: 0 0 40px; }
  .post-hero { max-width: 720px; margin: 0 0 40px; border: 1px solid var(--border-subtle); border-radius: var(--radius-lg); overflow: hidden; }
  .post-hero img { display: block; width: 100%; height: auto; }

  .post-body { padding: 0 0 96px; max-width: 720px; }
  .post-body h3 { font-size: 24px; font-weight: 500; margin: 36px 0 12px; color: #FFF; }
  .post-body p, .post-body ul, .post-body ol { font-size: 16px; line-height: 1.75; color: var(--fg-2); margin: 0 0 18px; }
  .post-body p:first-of-type { color: var(--fg-1); font-size: 18px; }
  .post-body strong { color: #FFF; font-weight: 500; }
  .post-body em { color: var(--color-accent-vivid); font-style: normal; }
  .post-body blockquote { border-left: 2px solid var(--color-accent-vivid); padding: 4px 0 4px 20px; margin: 24px 0; font-size: 17px; line-height: 1.7; color: var(--fg-1); }
  .post-body ul li { padding-left: 4px; }
  .post-body ul li::marker { color: var(--color-accent-vivid); }
  .post-body .footnote { margin-top: 36px; padding-top: 20px; border-top: 1px solid var(--border-subtle); font-size: 12px; color: var(--fg-3); display: flex; gap: 12px; flex-wrap: wrap; }
  .post-body .footnote span::before { content: "▸ "; color: var(--color-accent-vivid); }

  .speaking-cta {
    margin-top: 36px; padding: 24px 26px;
    background: var(--bg-card); border: 1px solid var(--border-subtle); border-radius: var(--radius-lg);
  }
  .speaking-cta h3 { font-size: 16px; font-weight: 500; color: #FFF; margin: 0 0 8px; }
  .speaking-cta p { font-size: 14px; line-height: 1.65; color: var(--fg-2); margin: 0 0 14px; }
  .speaking-cta a.bolt { font-size: 14px; }
</style>
<script src="/nav.js"></script>
</head>
<body class="bolt-os">

<a href="#main" class="skip-link">Skip to main content</a>

<site-header></site-header>

<main class="atmos" data-screen-label="essay" id="main">
  <div class="page-wrap page-wrap--narrow">
    <div class="post-header">
      <a href="/blog" class="bolt back-link">← All essays</a>
      <div class="section-eyebrow"><span class="num">{{ category }}</span> {{ date | readableDate }} · {{ readTime }}</div>
      <h1>{{ title }}</h1>
      <p class="post-desc">{{ description }}</p>
    </div>
    {%- if heroImage %}
    <div class="post-hero"><img src="{{ heroImage }}" alt="{{ title }}" width="1400" height="788"></div>
    {%- endif %}
    <article class="post-body">
      {{ content | safe }}
      {%- if originalUrl %}
      <div class="footnote">
        <span>Originally published on LinkedIn · {{ originalDate }}</span>
        <span><a class="bolt" href="{{ originalUrl }}" target="_blank" rel="noopener">View original ↗</a></span>
      </div>
      {%- endif %}
      {%- if category == "Case Study" %}
      <div class="speaking-cta">
        <h3>Bring this story to your audience</h3>
        <p>This case study informs how Jason talks about product strategy, media, and building under uncertainty on stage.</p>
        {%- if relatedTalkSlug %}
        <a class="bolt" href="/speaking/{{ relatedTalkSlug }}/">{{ relatedTalkTitle }} →</a>
        {%- else %}
        <a class="bolt" href="/speaking">Explore speaking topics →</a>
        {%- endif %}
      </div>
      {%- endif %}
    </article>
  </div>
</main>

<site-footer></site-footer>

</body>
</html>
